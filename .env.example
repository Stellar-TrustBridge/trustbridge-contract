# Example environment variables for local development and deployment.
# Copy to `.env` and fill in values. Never commit `.env`.

# Stellar network: testnet | mainnet | futurenet
NETWORK=testnet

# Stellar CLI identity name (must be funded on the target network)
SOURCE=default

# Contract admin G-address (set at initialization; cannot be changed)
ADMIN=G...

# Deployed contract ID (populated after running scripts/deploy.sh)
CONTRACT_ID=C...

# Registration example values
GITHUB_USER=octocat
STELLAR_ADDR=G...

# Stellar CLI contract alias
ALIAS=trustbridge
